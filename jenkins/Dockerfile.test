FROM mcr.microsoft.com/dotnet/sdk:8.0
WORKDIR /src

# Copy both csproj files first so Docker can cache the restore layer
COPY Hummingbird.API.csproj .
COPY Hummingbird.API.Tests/Hummingbird.API.Tests.csproj Hummingbird.API.Tests/

# Single restore covers both projects (including PrivateAssets analyzers in the main csproj)
RUN dotnet restore Hummingbird.API.Tests/Hummingbird.API.Tests.csproj

COPY . .

# Pre-build so the CMD can skip the build step
RUN dotnet build Hummingbird.API.Tests/Hummingbird.API.Tests.csproj -c Debug --no-restore

CMD ["dotnet", "test", "Hummingbird.API.Tests/Hummingbird.API.Tests.csproj", \
     "--verbosity", "normal", \
     "--no-build", \
     "--logger", "junit;LogFilePath=/TestResults/junit-results.xml"]
